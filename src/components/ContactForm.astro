---
---

<section class="py-32 bg-black px-6" id="contact">
    <div class="max-w-7xl mx-auto flex flex-col md:flex-row gap-20 items-stretch">
        <div class="flex-1 flex flex-col justify-center">
            <h2 class="text-xs font-bold uppercase tracking-widest text-emerald-500 mb-4 stagger-reveal">聯繫我們</h2>
            <h3 class="text-5xl md:text-7xl font-black uppercase tracking-tighter mb-12 stagger-reveal delay-200">
                啟動您的 <br/> <span class="text-zinc-500">永續計畫</span>
            </h3>
            
            <div class="space-y-10 stagger-reveal delay-400">
                <div class="flex gap-6 items-center group">
                    <div class="w-12 h-12 border border-zinc-800 flex items-center justify-center group-hover:bg-emerald-500 transition-colors">
                        <i data-lucide="mail" class="w-5 h-5 group-hover:text-black transition-colors"></i>
                    </div>
                    <div>
                        <span class="text-[10px] font-black uppercase tracking-widest text-zinc-500">電子信箱</span>
                        <a href="mailto:sustainablemans@gmail.com" class="block text-xl font-bold hover:text-emerald-500 transition-colors">sustainablemans@gmail.com</a>
                    </div>
                </div>
                
                <div class="flex gap-6 items-center group">
                    <div class="w-12 h-12 border border-zinc-800 flex items-center justify-center group-hover:bg-emerald-500 transition-colors">
                        <i data-lucide="phone" class="w-5 h-5 group-hover:text-black transition-colors"></i>
                    </div>
                    <div>
                        <span class="text-[10px] font-black uppercase tracking-widest text-zinc-500">聯絡電話</span>
                        <a href="tel:+886971007051" class="block text-xl font-bold hover:text-emerald-500 transition-colors">0971-007-051</a>
                    </div>
                </div>
                
                <div class="flex gap-6 items-center group">
                    <div class="w-12 h-12 border border-zinc-800 flex items-center justify-center group-hover:bg-emerald-500 transition-colors">
                        <i data-lucide="map-pin" class="w-5 h-5 group-hover:text-black transition-colors"></i>
                    </div>
                    <div>
                        <span class="text-[10px] font-black uppercase tracking-widest text-zinc-500">公司地址</span>
                        <p class="text-xl font-bold">811 高雄市 楠梓區 秀群路499巷28號六樓</p>
                    </div>
                </div>
            </div>
        </div>

        <div class="flex-1 bg-zinc-900 p-10 md:p-16 border-t-8 border-yellow-400 shadow-3xl stagger-reveal delay-600">
            <form class="space-y-8">
                <div class="space-y-2">
                    <label class="text-[10px] font-black uppercase tracking-widest text-zinc-400">合作類型 / Type</label>
                    <div class="relative group">
                        <select class="w-full bg-black border border-zinc-800 p-5 font-bold text-sm uppercase tracking-widest focus:border-yellow-400 outline-none appearance-none cursor-pointer">
                            <option value="">請選擇合作項目...</option>
                            <option value="training">桌遊種子教師培訓</option>
                            <option value="carbon">ISO 碳盤查/ESG 顧問</option>
                            <option value="agri">農企合作/永續採購</option>
                            <option value="other">其他合作洽詢</option>
                        </select>
                        <i data-lucide="chevron-down" class="absolute right-5 top-1/2 -translate-y-1/2 w-4 h-4 text-zinc-500 pointer-events-none group-hover:text-yellow-400"></i>
                    </div>
                </div>

                <div class="space-y-2">
                    <label class="text-[10px] font-black uppercase tracking-widest text-zinc-400">單位名稱 / Organization</label>
                    <input type="text" placeholder="王小明 / XX 科技公司" class="w-full bg-black border border-zinc-800 p-5 font-bold text-sm uppercase tracking-widest focus:border-yellow-400 outline-none transition-colors" />
                </div>

                <div class="space-y-2">
                    <label class="text-[10px] font-black uppercase tracking-widest text-zinc-400">電子郵件 / Email</label>
                    <input type="email" placeholder="your.email@example.com" class="w-full bg-black border border-zinc-800 p-5 font-bold text-sm uppercase tracking-widest focus:border-yellow-400 outline-none transition-colors" />
                </div>

                <div class="space-y-2">
                    <label class="text-[10px] font-black uppercase tracking-widest text-zinc-400">需求描述 / Message</label>
                    <textarea rows="4" placeholder="請簡述您的需求..." class="w-full bg-black border border-zinc-800 p-5 font-bold text-sm uppercase tracking-widest focus:border-yellow-400 outline-none transition-colors"></textarea>
                </div>

                <button type="submit" class="huemor-btn-primary w-full shadow-2xl">
                    送出洽詢表單
                </button>
            </form>
        </div>
    </div>
</section>
