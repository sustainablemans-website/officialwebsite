---
import ServiceCard from './ServiceCard.astro';
import services from '../data/services.json';
---

<section class="py-32 px-6 bg-transparent" id="services">
    <div class="max-w-7xl mx-auto">
        <div class="mb-24 flex flex-col md:flex-row justify-between items-end gap-8">
            <div class="max-w-2xl">
                <h2 class="text-xs font-bold uppercase tracking-widest text-emerald-600 mb-4 stagger-reveal">我們的核心服務</h2>
                <h3 class="text-5xl md:text-7xl font-black uppercase tracking-tighter stagger-reveal delay-200 text-stone-900">
                    永續策略 <br/> <span class="text-stone-400">轉型引路人</span>
                </h3>
            </div>
            <div class="md:text-right max-w-sm stagger-reveal delay-400">
                <p class="text-stone-500 font-bold uppercase tracking-widest text-sm">
                    致力於透過專業顧問與創新教育，為台灣打造完整的永續生態圈。
                </p>
            </div>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-2 gap-10">
            {services.map(service => (
                <ServiceCard {...service} />
            ))}
        </div>
    </div>
</section>
