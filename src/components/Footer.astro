---
import site from '../data/site.json';

const links = {
	'關於我們': [
		{ label: '品牌故事', href: '/about/' },
		{ label: '永續承諾', href: '/impact/' },
		{ label: '專業團隊', href: '/about/' },
		{ label: '社會使命', href: '/about/' }
	],
	'核心服務': [
		{ label: '空調專利節能解決方案', href: '/services/' },
		{ label: 'ISO 14064 碳盤查', href: '/services/' },
		{ label: 'ISO 14067 碳足跡', href: '/services/' },
		{ label: 'ESG 策略桌遊培訓', href: '/services/' }
	],
	'法律與隱私': [
		{ label: '服務條款', href: '/terms' },
		{ label: '隱私權政策', href: '/privacy' },
		{ label: 'Cookie 政策', href: '/privacy' }
	]
};
---

<footer class="border-t border-white/5 pt-40 pb-20 px-6 overflow-hidden relative">
    <!-- Subtle Background Glow -->
    <div class="absolute bottom-0 left-0 w-full h-full bg-[radial-gradient(circle_at_bottom_left,_var(--tw-gradient-stops))] from-emerald-500/5 via-transparent to-transparent pointer-events-none"></div>

    <div class="max-w-7xl mx-auto relative z-10">
        <div class="flex flex-col lg:flex-row justify-between gap-24 mb-32">
            <div class="max-w-md">
                <a href="/" class="flex items-center gap-3 mb-10 stagger-reveal">
                    <img src="/images/logo.png" alt="杉蔓有限公司" class="w-10 h-10 object-contain" />
                    <span class="text-2xl font-black uppercase tracking-tighter text-white">杉蔓有限公司</span>
                </a>
                <p class="text-zinc-400 font-medium uppercase tracking-[0.2em] text-[10px] leading-[2] mb-12 stagger-reveal delay-200">
                    致力於透過專業顧問與創新教育，為台灣打造完整的永續生態圈。淨零時代，高效永續轉型策略夥伴。
                </p>
                <div class="flex gap-6 stagger-reveal delay-400">
                    <a href={site.social.facebook} target="_blank" rel="noopener noreferrer" class="w-12 h-12 border border-white/5 flex items-center justify-center hover:bg-emerald-500 transition-all duration-500 group rounded-full">
                        <svg class="w-5 h-5 fill-zinc-400 group-hover:fill-black" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
                            <path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/>
                        </svg>
                    </a>
                    <a href={site.social.instagram} target="_blank" rel="noopener noreferrer" class="w-12 h-12 border border-white/5 flex items-center justify-center hover:bg-emerald-500 transition-all duration-500 group rounded-full">
                        <svg class="w-5 h-5 fill-zinc-400 group-hover:fill-black" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
                            <path d="M12 0C8.74 0 8.333.015 7.053.072 5.775.132 4.905.333 4.14.63c-.789.306-1.459.717-2.126 1.384S.935 3.35.63 4.14C.333 4.905.131 5.775.072 7.053.012 8.333 0 8.74 0 12s.015 3.667.072 4.947c.06 1.277.261 2.148.558 2.913.306.788.717 1.459 1.384 2.126.667.666 1.336 1.079 2.126 1.384.766.296 1.636.499 2.913.558C8.333 23.988 8.74 24 12 24s3.667-.015 4.947-.072c1.277-.06 2.148-.262 2.913-.558.788-.306 1.459-.718 2.126-1.384.666-.667 1.079-1.335 1.384-2.126.296-.765.499-1.636.558-2.913.06-1.28.072-1.687.072-4.947s-.015-3.667-.072-4.947c-.06-1.277-.262-2.149-.558-2.913-.306-.789-.718-1.459-1.384-2.126C21.066.935 20.397.525 19.61.22c-.765-.296-1.636-.499-2.913-.558C15.667.012 15.26 0 12 0zm0 2.16c3.203 0 3.585.016 4.85.071 1.17.055 1.805.249 2.227.415.562.217.96.477 1.382.896.419.42.679.819.896 1.381.164.422.36 1.057.413 2.227.057 1.266.07 1.646.07 4.85s-.015 3.585-.074 4.85c-.055 1.17-.249 1.805-.415 2.227-.214.562-.47 1.002-.898 1.43-.43.43-.87.684-1.432.898-.422.164-1.057.36-2.227.413-1.266.057-1.646.07-4.85.07s-3.585-.015-4.85-.074c-1.17-.055-1.805-.249-2.227-.415-.562-.214-1.002-.47-1.43-.898-.43-.43-.684-.87-.898-1.432-.164-.422-.36-1.057-.413-2.227-.057-1.266-.07-1.646-.07-4.85s.016-3.585.071-4.85c.055-1.17.249-1.805.415-2.227.217-.562.477-.96.896-1.382.42-.419.819-.679 1.381-.896.422-.164 1.057-.36 2.227-.413 1.266-.057 1.646-.07 4.85-.07zM12 5.838a6.162 6.162 0 100 12.324 6.162 6.162 0 000-12.324zM12 16a4 4 0 110-8 4 4 0 010 8zm6.406-11.845a1.44 1.44 0 100 2.88 1.44 1.44 0 000-2.88z"/>
                        </svg>
                    </a>
                    <a href={site.social.linkedin} target="_blank" rel="noopener noreferrer" class="w-12 h-12 border border-white/5 flex items-center justify-center hover:bg-emerald-500 transition-all duration-500 group rounded-full">
                        <svg class="w-5 h-5 fill-zinc-400 group-hover:fill-black" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
                            <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
                        </svg>
                    </a>
                </div>
            </div>

            <div class="grid grid-cols-2 md:grid-cols-3 gap-16 lg:gap-32">
                {Object.entries(links).map(([title, items], idx) => (
                    <div class="stagger-reveal" style={`transition-delay: ${idx * 150}ms`}>
                        <h4 class="text-[9px] font-black uppercase tracking-[0.4em] text-emerald-500 mb-10">{title}</h4>
                        <ul class="space-y-6">
                            {items.map(item => (
                                <li>
                                    <a href={item.href} class="text-[11px] font-bold uppercase tracking-[0.2em] text-zinc-300 hover:text-white transition-colors">{item.label}</a>
                                </li>
                            ))}
                        </ul>
                    </div>
                ))}
            </div>
        </div>

        <div class="pt-16 border-t border-white/5 flex flex-col md:flex-row justify-between items-center gap-10 stagger-reveal delay-700">
            <span class="text-[9px] font-black uppercase tracking-[0.3em] text-zinc-400 italic">{site.footer.copyright}</span>
            <span class="text-[9px] font-black uppercase tracking-[0.3em] text-zinc-400 flex items-center gap-4">
                Designed & Built by <a href="#" class="text-zinc-300 hover:text-emerald-500 transition-colors uppercase border-b border-zinc-700 hover:border-emerald-500">{site.footer.madeBy}</a>
            </span>
        </div>
    </div>
</footer>
