---
const mockups = [
    { src: '/images/mockup-esg.png', title: 'ESG Portal Design' },
    { src: '/images/bg-ai.png', title: 'AI Automation Vision' },
    { src: '/images/about.png', title: 'Expert Team' },
    { src: '/images/msrdk_solution.png', title: 'MSRDK Technical Diagram' }
];
---

<section class="py-32 px-6 overflow-hidden relative z-10" id="design-showcase">
    <div class="max-w-7xl mx-auto">
        <div class="mb-16">
            <h2 class="text-[10px] font-black uppercase tracking-[0.4em] text-emerald-500 mb-4 stagger-reveal active">Design & Strategy</h2>
            <h3 class="text-4xl font-black text-white tracking-tighter stagger-reveal active delay-200">
                數位與永續的 <span class="text-zinc-600 italic">視覺實踐</span>
            </h3>
        </div>

        <div class="grid grid-cols-2 md:grid-cols-4 gap-6">
            {mockups.map((mockup, idx) => (
                <div class="group relative aspect-square rounded-2xl overflow-hidden border border-white/5 bg-zinc-900/40 backdrop-blur-xl stagger-reveal active" style={`transition-delay: ${idx * 150}ms`}>
                    <img src={mockup.src} alt={mockup.title} class="w-full h-full object-cover opacity-60 group-hover:scale-110 group-hover:opacity-100 transition-all duration-1000 grayscale group-hover:grayscale-0" />
                    <div class="absolute inset-0 bg-gradient-to-t from-zinc-950/80 via-transparent to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-700"></div>
                    <div class="absolute bottom-4 left-4 right-4 translate-y-4 opacity-0 group-hover:translate-y-0 group-hover:opacity-100 transition-all duration-500">
                        <p class="text-[9px] font-black uppercase tracking-[0.2em] text-emerald-400 mb-1">Concept</p>
                        <p class="text-xs font-bold text-white tracking-tight">{mockup.title}</p>
                    </div>
                </div>
            ))}
        </div>
    </div>
</section>
