---
import activitiesData from '../data/activities.json';
const activities = activitiesData.activities;
---

<section class="py-40 px-6 relative overflow-hidden" id="activities">
    <!-- Subtle Background Glow -->
    <div class="absolute bottom-0 right-0 w-[600px] h-[600px] bg-emerald-500/5 blur-[120px] rounded-full pointer-events-none"></div>

    <div class="max-w-7xl mx-auto relative z-10">
        <div class="mb-32 flex flex-col md:flex-row justify-between items-end gap-12">
            <div class="max-w-3xl">
                <h2 class="text-xs font-black uppercase tracking-[0.4em] text-emerald-500 mb-6 stagger-reveal">Real Impact / 行動紀錄</h2>
                <h3 class="text-6xl md:text-8xl font-black uppercase tracking-tighter stagger-reveal delay-200 text-white leading-none">
                    永續種子 <br/> <span class="text-emerald-300/50">遍地開花</span>
                </h3>
            </div>
            <div class="md:text-right max-w-sm stagger-reveal delay-400">
                <p class="text-zinc-300 font-medium uppercase tracking-widest text-sm leading-relaxed">
                    見證我們在全台企業與校園中，<br/>播下的一顆顆永續種子。
                </p>
            </div>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-10">
            {activities.map((activity, index) => (
                <div class="group relative overflow-hidden bg-zinc-900/80 border border-white/5 hover:border-emerald-500/30 transition-all duration-500 stagger-reveal" style={`transition-delay: ${index * 100}ms`}>
                    <div class="aspect-[4/3] overflow-hidden relative">
                        <img 
                            src={activity.image} 
                            alt={activity.title} 
                            class="w-full h-full object-cover grayscale opacity-40 group-hover:grayscale-0 group-hover:opacity-100 group-hover:scale-105 transition-all duration-500"
                            loading="lazy"
                        />
                        <div class="absolute inset-0 bg-gradient-to-t from-zinc-950/80 to-transparent"></div>
                    </div>
                    <div class="p-10">
                        <span class="text-[9px] font-black uppercase tracking-[0.3em] text-emerald-500 mb-4 block">{activity.date}</span>
                        <h4 class="text-2xl font-black uppercase tracking-tighter group-hover:text-emerald-400 transition-colors text-white leading-tight">{activity.title}</h4>
                    </div>
                </div>
            ))}
        </div>
    </div>
</section>
