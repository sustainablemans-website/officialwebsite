---
import servicesData from '../data/services.json';
const services = servicesData.services;
const msrdk = services.find(s => s.title.includes('MS-RDK'));
---

<section class="relative pt-32 pb-16 px-6 z-20">
    <div class="max-w-7xl mx-auto">
        <div class="group relative overflow-hidden bg-white/[0.03] backdrop-blur-2xl border border-white/10 rounded-[2.5rem] p-8 md:p-12 shadow-2xl hover:border-emerald-500/30 transition-all duration-500">
            <!-- Animated Background Glow -->
            <div class="absolute top-0 right-0 w-[400px] h-[400px] bg-emerald-500/10 blur-[100px] rounded-full -translate-y-1/2 translate-x-1/2 group-hover:bg-emerald-500/20 transition-all duration-700"></div>

            <div class="flex flex-col lg:flex-row items-center gap-12 relative z-10">
                <!-- Data / Stat Side -->
                <div class="flex-shrink-0 w-full lg:w-1/3 space-y-6">
                    <div class="inline-flex items-center gap-2 px-4 py-2 bg-emerald-500 text-black text-[10px] font-black uppercase tracking-[0.2em] rounded-lg">
                        Flagship Technology
                    </div>
                    <div class="space-y-2">
                        <p class="text-emerald-400 font-bold uppercase tracking-widest text-xs">Japan Patent No. 6366832</p>
                        <h2 class="text-4xl md:text-5xl font-black text-white leading-tight">
                            MS-RDK <br/> <span class="text-emerald-500">空調專利節能</span>
                        </h2>
                    </div>
                    <div class="grid grid-cols-2 gap-4">
                        <div class="bg-white/5 p-4 rounded-xl border border-white/5">
                            <p class="text-[9px] font-bold text-zinc-500 uppercase tracking-widest mb-1">Carbon Reduction</p>
                            <p class="text-2xl font-black text-emerald-400">-25%</p>
                        </div>
                        <div class="bg-white/5 p-4 rounded-xl border border-white/5">
                            <p class="text-[9px] font-bold text-zinc-500 uppercase tracking-widest mb-1">Installation</p>
                            <p class="text-2xl font-black text-white">1 MIN</p>
                        </div>
                    </div>
                </div>

                <!-- Content/Description Side -->
                <div class="flex-grow space-y-8">
                    <p class="text-lg md:text-xl text-zinc-300 leading-relaxed font-medium">
                        {msrdk?.description}
                    </p>
                    <div class="flex flex-wrap gap-4">
                        <div class="flex items-center gap-3 px-5 py-3 bg-white/5 border border-white/10 rounded-xl">
                            <i data-lucide="check-circle" class="w-5 h-5 text-emerald-500"></i>
                            <span class="text-xs font-bold text-zinc-200 uppercase tracking-widest">無電熱干擾</span>
                        </div>
                        <div class="flex items-center gap-3 px-5 py-3 bg-white/5 border border-white/10 rounded-xl">
                            <i data-lucide="check-circle" class="w-5 h-5 text-emerald-500"></i>
                            <span class="text-xs font-bold text-zinc-200 uppercase tracking-widest">陶瓷遠紅外線</span>
                        </div>
                        <div class="flex items-center gap-3 px-5 py-3 bg-white/5 border border-white/10 rounded-xl">
                            <i data-lucide="check-circle" class="w-5 h-5 text-emerald-500"></i>
                            <span class="text-xs font-bold text-zinc-200 uppercase tracking-widest">免工地施工</span>
                        </div>
                    </div>
                    <div class="pt-6 border-t border-white/5 flex justify-between items-center">
                        <a href="/services/msrdk/" class="group/btn inline-flex items-center gap-4 text-emerald-400 font-black uppercase text-xs tracking-[0.3em] hover:text-white transition-colors">
                            啟動節能方案 <i data-lucide="arrow-right" class="w-5 h-5 group-hover/btn:translate-x-2 transition-transform"></i>
                        </a>
                        <div class="flex -space-x-3 grayscale opacity-30">
                             <img src="/images/partners/EKO.jpg" class="w-10 h-10 rounded-full border-2 border-zinc-950 object-cover" />
                             <img src="/images/partners/PLAB.jpg" class="w-10 h-10 rounded-full border-2 border-zinc-950 object-cover" />
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>
