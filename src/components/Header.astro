---
const { 
	isDark = false,
	navItems = [
		{ label: '首頁', href: '/' },
		{ label: '關於我們', href: '/about/' },
		{ label: '服務項目', href: '/services/' },
		{ label: '影響力', href: '/impact/' }
	] 
} = Astro.props;
---

<header class="fixed top-8 left-0 w-full z-50 px-6 transition-all duration-500" id="main-header">
	<div class="max-w-5xl mx-auto flex justify-between items-center bg-white/5 backdrop-blur-2xl border border-white/10 px-10 py-4 rounded-full shadow-2xl transition-all duration-500" id="header-pill">
		<!-- Logo Section -->
		<a href="/" class="flex items-center gap-3 group">
			<img src="/images/logo.png" alt="杉蔓有限公司" class="w-8 h-8 object-contain transition-transform duration-500 group-hover:scale-110" />
			<span class="text-sm font-black uppercase tracking-tighter text-white group-hover:text-emerald-500 transition-colors duration-300">
				Sustainable Man
			</span>
		</a>

		<!-- Desktop Navigation -->
		<nav class="hidden md:flex items-center gap-8">
			{navItems.map((item: any) => (
				<a href={item.href} class="text-[10px] font-black uppercase tracking-[0.3em] text-zinc-200 hover:text-emerald-400 transition-colors duration-300 nav-link">
					{item.label}
				</a>
			))}
			<a href="/contact/" class="ml-4 px-6 py-2.5 bg-emerald-500 text-black text-[10px] font-black uppercase tracking-[0.2em] hover:bg-white transition-all duration-500 rounded-full shadow-lg shadow-emerald-500/20">
				Get Started
			</a>
		</nav>

		<!-- Mobile Menu Toggle -->
		<button class="md:hidden p-2 text-white hover:text-emerald-500 transition-colors duration-300" aria-label="Toggle Menu" id="menu-btn">
			<i data-lucide="menu" class="w-6 h-6"></i>
		</button>
	</div>
</header>

<style>
	@reference "../styles/global.css";
</style>

<script is:inline>
	const header = document.getElementById('main-header');
	const pill = document.getElementById('header-pill');
	window.addEventListener('scroll', () => {
		if (window.scrollY > 50) {
			header.classList.remove('top-8');
			header.classList.add('top-4');
			pill.classList.add('bg-zinc-950/80', 'backdrop-blur-3xl', 'border-white/20', 'py-3');
			pill.classList.remove('bg-white/5', 'py-4');
		} else {
			header.classList.remove('top-4');
			header.classList.add('top-8');
			pill.classList.remove('bg-zinc-950/80', 'backdrop-blur-3xl', 'border-white/20', 'py-3');
			pill.classList.add('bg-white/5', 'py-4');
		}
	});
</script>
