---
const { 
	isDark = false,
	navItems = [
		{ label: '首頁', href: '/#home' },
		{ label: '服務', href: '/#services' },
		{ label: '活動', href: '/#activities' },
		{ label: '承諾', href: '/#impact' },
		{ label: '團隊', href: '/#team' },
		{ label: '知識', href: '/#knowledge' }
	] 
} = Astro.props;
---

<header class={`fixed top-0 left-0 w-full z-50 transition-all duration-300 px-6 py-4 ${isDark ? 'header-initial-dark' : 'header-initial-light'}`} id="main-header">
	<div class="max-w-7xl mx-auto flex justify-between items-center">
		<!-- Logo Section -->
		<a href="/" class="flex items-center gap-2 group">
			<img src="/images/logo.png" alt="杉蔓有限公司" class="w-10 h-10 object-contain group-hover:rotate-12 transition-transform duration-300" />
			<span class={`text-xl font-black uppercase tracking-tighter group-hover:text-emerald-500 transition-colors duration-300 px-2 py-1 ${isDark ? 'text-white' : 'text-stone-900'}`} id="header-logo-text">
				杉蔓有限公司
			</span>
		</a>

		<!-- Desktop Navigation -->
		<nav class="hidden md:flex items-center gap-8">
			{navItems.map(item => (
				<a href={item.href} class={`text-xs font-bold uppercase tracking-widest hover:text-emerald-500 transition-colors duration-300 nav-link ${isDark ? 'text-white' : 'text-stone-800'}`}>
					{item.label}
				</a>
			))}
			<a href="/#contact" class="px-6 py-2 bg-yellow-400 text-stone-900 text-xs font-black uppercase tracking-widest hover:bg-emerald-500 hover:text-white transition-colors duration-300 shadow-[4px_4px_0px_#000]">
				立即洽詢
			</a>
		</nav>

		<!-- Mobile Menu Toggle -->
		<button class={`md:hidden p-2 hover:text-emerald-600 transition-colors duration-300 group ${isDark ? 'text-white' : 'text-stone-800'}`} aria-label="Toggle Menu" id="menu-btn">
			<i data-lucide="menu" class="w-6 h-6"></i>
		</button>
	</div>
</header>

<style>
	@reference "../styles/global.css";

	.header-initial-dark .nav-link { @apply text-white; }
	.header-initial-dark #header-logo-text { @apply text-white; }
	
	.scrolled #header-logo-text { @apply text-stone-900; }
	.scrolled .nav-link { @apply text-stone-800; }
</style>

<script is:inline>
	const header = document.getElementById('main-header');
	window.addEventListener('scroll', () => {
		if (window.scrollY > 50) {
			header.classList.add('bg-white/90', 'backdrop-blur-md', 'shadow-sm', 'py-2', 'scrolled');
			header.classList.remove('py-4');
		} else {
			header.classList.remove('bg-white/90', 'backdrop-blur-md', 'shadow-sm', 'py-2', 'scrolled');
			header.classList.add('py-4');
		}
	});

	// Mobile menu logic (can be expanded)
	const menuBtn = document.getElementById('menu-btn');
	menuBtn?.addEventListener('click', () => {
		// Just a simple toggle for now as requested by Huemor (keep it minimal)
	});
</script>
