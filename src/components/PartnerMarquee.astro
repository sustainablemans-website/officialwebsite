---
const partners = [
	{ name: 'Partner 1', logo: 'https://placehold.co/200x80/10b981/ffffff/png?text=PARTNER+1' },
	{ name: 'Partner 2', logo: 'https://placehold.co/200x80/2563eb/ffffff/png?text=PARTNER+2' },
	{ name: 'Partner 3', logo: 'https://placehold.co/200x80/f59e0b/ffffff/png?text=PARTNER+3' },
	{ name: 'Partner 4', logo: 'https://placehold.co/200x80/db2777/ffffff/png?text=PARTNER+4' },
	{ name: 'Partner 5', logo: 'https://placehold.co/200x80/7c3aed/ffffff/png?text=PARTNER+5' },
	{ name: 'Partner 6', logo: 'https://placehold.co/200x80/059669/ffffff/png?text=PARTNER+6' },
];

const duplicatedPartners = [...partners, ...partners];
---

<section class="py-20 bg-zinc-900 overflow-hidden border-y border-zinc-800">
	<div class="max-w-7xl mx-auto px-6 mb-12">
		<h2 class="text-xs font-bold uppercase tracking-widest text-emerald-500 mb-2">我們信賴的永續夥伴</h2>
		<div class="w-20 h-1 bg-emerald-500"></div>
	</div>

	<div class="relative flex items-center overflow-hidden">
		<div class="animate-marquee flex gap-12 items-center">
			{duplicatedPartners.map((partner) => (
				<div class="flex-shrink-0 grayscale hover:grayscale-0 transition-all duration-300 transform hover:scale-110">
					<img 
						src={partner.logo} 
						alt={partner.name} 
						class="h-12 md:h-16 w-auto object-contain opacity-50 hover:opacity-100"
                        loading="lazy"
					/>
				</div>
			))}
		</div>
	</div>
</section>
