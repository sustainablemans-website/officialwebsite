---
import partners from '../data/partners.json';

const duplicatedPartners = [...partners, ...partners];
---

<section class="py-24 bg-transparent overflow-hidden border-y border-white/5 relative">
    <!-- Subtle Background Glow -->
    <div class="absolute inset-0 bg-[radial-gradient(circle_at_center,_var(--tw-gradient-stops))] from-emerald-500/5 via-transparent to-transparent pointer-events-none"></div>

	<div class="max-w-7xl mx-auto px-6 mb-16 relative z-10">
		<h2 class="text-[10px] font-black uppercase tracking-[0.4em] text-emerald-500 mb-4 stagger-reveal">Trusted Ecosystem Partners / 核心合作夥伴</h2>
		<div class="w-16 h-[1px] bg-zinc-800"></div>
	</div>

	<div class="relative flex items-center overflow-hidden">
		<div class="animate-marquee flex gap-20 items-center">
			{duplicatedPartners.map((partner) => (
				<div class="flex-shrink-0 transition-all duration-500 hover:scale-110 filter brightness-[0.4] hover:brightness-100 invert hover:invert-0 opacity-40 hover:opacity-100">
					<img 
						src={partner.logo} 
						alt={partner.name} 
						class="h-10 md:h-14 w-auto object-contain"
                        loading="lazy"
					/>
				</div>
			))}
		</div>
	</div>
</section>
