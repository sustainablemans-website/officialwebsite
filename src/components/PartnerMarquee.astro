---
import partners from '../data/partners.json';

const duplicatedPartners = [...partners, ...partners];
---

<section class="py-20 bg-gradient-to-r from-stone-100 via-white to-stone-100 overflow-hidden border-y border-stone-200 relative shadow-inner">
	<div class="max-w-7xl mx-auto px-6 mb-12 relative z-10">
		<h2 class="text-[10px] font-black uppercase tracking-[0.4em] text-emerald-600 mb-4 stagger-reveal">Trusted Ecosystem Partners / 合作夥伴</h2>
		<div class="w-12 h-[2px] bg-yellow-400"></div>
	</div>

	<div class="relative flex items-center overflow-hidden">
		<div class="animate-marquee flex gap-12 items-center">
			{duplicatedPartners.map((partner) => (
				<div class="flex-shrink-0 grayscale hover:grayscale-0 transition-all duration-300 transform hover:scale-110">
					<img 
						src={partner.logo} 
						alt={partner.name} 
						class="h-12 md:h-16 w-auto object-contain opacity-50 hover:opacity-100"
                        loading="lazy"
					/>
				</div>
			))}
		</div>
	</div>
</section>
