---
import { getCollection } from 'astro:content';

const allArticles = await getCollection('articles');

// Debug: Log article count - this will show up in the terminal
console.log(`[KnowledgeCenter] Found ${allArticles.length} articles in collection.`);

// Sort by date or id if needed, for now just as is
const articles = allArticles.map(article => {
    // Robust slug generation that strips any directory prefix or extension
    const cleanId = article.id
        .split('/')
        .pop()
        .replace(/\.(md|mdx)$/, '')
        .replace(/^\.\//, '');
        
    return {
        id: cleanId,
        title: article.data.title,
        category: article.data.category,
        description: article.data.description,
        accent: article.data.accent || 'emerald'
    };
});

const categoryColors = {
	emerald: "text-emerald-500",
	blue: "text-blue-500",
	yellow: "text-yellow-500",
    "green-primary": "text-emerald-500",
    "blue-accent": "text-blue-400"
};
---

<section class="py-32 bg-stone-50 px-6" id="knowledge">
    <div class="max-w-7xl mx-auto">
        <div class="flex flex-col md:flex-row justify-between items-end gap-8 mb-24">
            <div class="max-w-xl">
                <h2 class="text-xs font-bold uppercase tracking-widest text-emerald-600 mb-4 stagger-reveal">永續知識中心</h2>
                <h3 class="text-5xl md:text-7xl font-black uppercase tracking-tighter mb-8 stagger-reveal delay-200 text-stone-900">
                    淨零轉型 <br/> <span class="text-emerald-700">深度解析</span>
                </h3>
            </div>
            <div class="md:text-right stagger-reveal delay-400">
                <a href="#knowledge" class="px-8 py-4 bg-emerald-600 text-white font-black uppercase text-xs tracking-widest hover:bg-yellow-400 hover:text-stone-900 transition-colors shadow-md">
                    查看全部文章
                </a>
            </div>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-3 gap-10">
            {articles.length > 0 ? articles.map((article, index) => (
                <article class={`group p-10 bg-white border border-stone-200 hover:border-emerald-500 hover:shadow-xl transition-all duration-500 stagger-reveal`} style={`transition-delay: ${500 + index * 100}ms`}>
                    <span class={`text-[10px] uppercase font-black tracking-widest mb-4 inline-block ${categoryColors[article.accent || 'emerald']}`}>
                        【{article.category}】
                    </span>
                    <h4 class="text-2xl font-black uppercase tracking-tighter mb-6 text-stone-900 group-hover:text-emerald-700 transition-colors leading-tight">
                        {article.title}
                    </h4>
                    <p class="text-stone-600 font-bold uppercase tracking-widest text-[11px] leading-loose mb-10 group-hover:text-stone-800 transition-colors">
                        {article.description}
                    </p>
                    <a href={`/knowledge/${article.id}/`} class="text-xs font-black uppercase tracking-widest flex items-center gap-2 text-stone-800 group-hover:text-emerald-600 group-hover:translate-x-2 transition-all">
                        閱讀全文 <i data-lucide="arrow-right" class="w-4 h-4"></i>
                    </a>
                </article>
            )) : (
                <div class="col-span-full py-20 text-center border-2 border-dashed border-zinc-900 rounded-xl bg-zinc-950/50">
                    <p class="text-white font-black uppercase tracking-widest text-sm animate-pulse">正在載入專刊內容...</p>
                </div>
            )}
        </div>
    </div>
</section>
