---
interface Props {
	title: string;
	description: string;
	icon: string;
	accent: string;
}

const { title, description, icon, accent = "emerald" } = Astro.props;

const accentColors = {
	emerald: "border-emerald-500 text-emerald-500",
	blue: "border-blue-500 text-blue-500",
	yellow: "border-yellow-400 text-yellow-400",
	purple: "border-purple-500 text-purple-500"
};

const accentBg = {
	emerald: "bg-emerald-500",
	blue: "bg-blue-500",
	yellow: "bg-yellow-400",
	purple: "bg-purple-500"
};
---

<div class={`group p-10 bg-zinc-900 border-t-8 ${accentColors[accent]} shadow-2xl transition-all duration-500 transform hover:-translate-y-4 hover:bg-zinc-800 flex flex-col justify-between h-full stagger-reveal`}>
    <div>
        <div class={`w-16 h-16 ${accentBg[accent]} rounded-full flex items-center justify-center mb-10 group-hover:rotate-[360deg] transition-transform duration-1000`}>
            <i data-lucide={icon} class="w-8 h-8 text-black"></i>
        </div>
        <h3 class="text-3xl font-black uppercase tracking-tighter mb-4 group-hover:text-white transition-colors">
            {title}
        </h3>
        <p class="text-zinc-400 text-lg leading-relaxed group-hover:text-zinc-300 transition-colors">
            {description}
        </p>
    </div>
    
    <div class="mt-12 pt-6 border-t border-zinc-800 flex justify-between items-end">
        <span class="text-2xl font-black uppercase opacity-20 group-hover:opacity-100 transition-opacity">詢價專案</span>
        <button class={`p-3 ${accentBg[accent]} text-black rounded-full hover:scale-110 transition-transform`}>
            <i data-lucide="arrow-right" class="w-6 h-6"></i>
        </button>
    </div>
</div>
