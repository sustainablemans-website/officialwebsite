---
interface Props {
	slug: string;
	title: string;
	description: string;
	icon: string;
	accent: string;
	isFlagship?: boolean;
	image?: string;
}

const { slug, title, description, icon, accent = "emerald", isFlagship = false, image = "/images/msrdk_solution.png" } = Astro.props;

const accentColors = {
	emerald: "border-emerald-500 text-emerald-500",
	blue: "border-blue-500 text-blue-500",
	yellow: "border-yellow-400 text-yellow-400",
	purple: "border-purple-500 text-purple-500"
};

const accentBg = {
	emerald: "bg-emerald-500",
	blue: "bg-blue-500",
	yellow: "bg-yellow-400",
	purple: "bg-purple-500"
};
---

<div class="group px-8 py-16 bg-white/[0.02] backdrop-blur-3xl border border-white/5 rounded-[2rem] hover:border-emerald-500/30 transition-all duration-700 flex flex-col items-center text-center h-full stagger-reveal active shadow-2xl">
    <!-- Centered Glow Icon -->
    <div class="relative mb-12">
        <div class="absolute inset-0 bg-emerald-500/20 blur-2xl rounded-full scale-150 opacity-0 group-hover:opacity-100 transition-opacity duration-700"></div>
        <div class={`w-20 h-20 rounded-2xl bg-zinc-900 border border-white/10 flex items-center justify-center relative z-10 transition-all duration-500 group-hover:border-emerald-500/50 group-hover:rotate-12`}>
            <i data-lucide={icon} class="w-10 h-10 text-emerald-500"></i>
        </div>
    </div>

    <!-- Title and Content -->
    <div class="space-y-6">
        <h3 class="text-2xl font-black uppercase tracking-tighter text-white transition-colors group-hover:text-emerald-400">
            {title}
        </h3>
        <p class="text-zinc-300 text-sm leading-relaxed font-medium group-hover:text-white transition-colors">
            {description}
        </p>
    </div>

    <!-- Bottom Action -->
    <div class="mt-12 pt-8 border-t border-white/5 w-full flex justify-center">
        <a href={`/services/${slug}/`} class="text-[10px] font-black uppercase tracking-[0.3em] text-zinc-400 group-hover:text-emerald-500 transition-colors flex items-center gap-2">
            Learn More <i data-lucide="arrow-right" class="w-4 h-4"></i>
        </a>
    </div>
</div>

<style>
    @keyframes float {
        0%, 100% { transform: translateY(0); }
        50% { transform: translateY(-10px); }
    }
    .animate-float {
        animation: float 4s ease-in-out infinite;
    }
</style>
