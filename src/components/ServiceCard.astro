---
interface Props {
	title: string;
	description: string;
	icon: string;
	accent: string;
	isFlagship?: boolean;
	image?: string;
}

const { title, description, icon, accent = "emerald", isFlagship = false, image = "/images/msrdk_solution.png" } = Astro.props;

const accentColors = {
	emerald: "border-emerald-500 text-emerald-500",
	blue: "border-blue-500 text-blue-500",
	yellow: "border-yellow-400 text-yellow-400",
	purple: "border-purple-500 text-purple-500"
};

const accentBg = {
	emerald: "bg-emerald-500",
	blue: "bg-blue-500",
	yellow: "bg-yellow-400",
	purple: "bg-purple-500"
};
---

<div class={`group p-10 bg-white/95 backdrop-blur-md border-t-8 ${accentColors[accent]} shadow-lg transition-all duration-700 transform hover:-translate-y-4 flex flex-col justify-between h-full stagger-reveal ${isFlagship ? 'md:col-span-2 ring-1 ring-emerald-500/20 shadow-emerald-500/5 hover:shadow-emerald-500/20' : ''}`}>
    <div class={isFlagship ? 'grid grid-cols-1 md:grid-cols-2 gap-12 items-center' : ''}>
        <div>
            <div class={`w-16 h-16 ${accentBg[accent]} rounded-full flex items-center justify-center mb-10 group-hover:rotate-[360deg] transition-transform duration-1000 shadow-xl shadow-emerald-500/10`}>
                <i data-lucide={icon} class="w-8 h-8 text-black"></i>
            </div>
            
            {!isFlagship && image && (
                <div class="relative overflow-hidden aspect-[16/10] bg-stone-100/50 border border-stone-200 rounded-lg mb-8 group-hover:border-emerald-500/30 transition-all duration-700">
                    <img src={image} alt={title} class="w-full h-full object-cover grayscale opacity-80 group-hover:grayscale-0 group-hover:opacity-100 group-hover:scale-105 transition-all duration-1000" />
                    <div class="absolute inset-0 bg-gradient-to-t from-black/20 to-transparent"></div>
                </div>
            )}

            {isFlagship && (
                <div class="flex items-center gap-3 mb-6">
                    <span class="bg-emerald-600 text-white text-[9px] font-black uppercase px-3 py-1 tracking-[0.2em] rounded-full shadow-sm">Flagship / 旗艦技術</span>
                    <span class="bg-stone-100 text-stone-500 border border-stone-200 text-[9px] font-bold uppercase px-3 py-1 tracking-widest rounded-full">日本專利：特許第 6366832 號</span>
                </div>
            )}
            <h3 class={`font-black uppercase tracking-tighter mb-6 transition-colors leading-tight ${isFlagship ? 'text-4xl md:text-6xl text-stone-900 group-hover:text-emerald-600' : 'text-3xl text-stone-800 group-hover:text-emerald-700'}`}>
                {title}
            </h3>
            <p class="text-stone-600 text-lg md:text-xl leading-relaxed group-hover:text-stone-950 transition-colors font-medium">
                {description}
            </p>
        </div>
        
        {isFlagship && image && (
            <div class="relative overflow-hidden aspect-video bg-teal-50/50 border border-emerald-100 rounded-lg shadow-2xl group transition-all duration-700 hover:ring-2 hover:ring-emerald-500/30">
                <img src={image} alt={title} class="w-full h-full object-cover grayscale opacity-90 group-hover:grayscale-0 group-hover:opacity-100 group-hover:scale-110 transition-all duration-1000" />
                <div class="absolute inset-0 bg-gradient-to-t from-emerald-950/40 via-transparent to-transparent group-hover:via-emerald-500/5 transition-all duration-700"></div>
                <div class="absolute bottom-4 right-4 bg-white/90 backdrop-blur-sm p-4 border border-emerald-500/20 shadow-xl">
                    <p class="text-[8px] font-black uppercase text-emerald-800 text-center tracking-widest mb-1">減碳效益</p>
                    <p class="text-2xl font-black text-stone-900 italic">-25%<span class="text-xs ml-1">CO₂e</span></p>
                </div>
            </div>
        )}
    </div>
    
    <div class="mt-12 pt-8 border-t border-stone-100 flex justify-between items-center">
        <span class="text-xs font-black uppercase text-stone-400 group-hover:text-emerald-600 transition-colors tracking-widest flex items-center gap-2">
            {isFlagship ? "閱讀技術專刊與 ROI 分析" : "產品諮詢與報價"}
            <i data-lucide="external-link" class="w-3 h-3"></i>
        </span>
        <a href={isFlagship ? "/knowledge/article-msrdk/" : "#contact"} class={`p-5 ${accentBg[accent]} text-black rounded-full hover:scale-110 shadow-xl transition-all duration-500 group-hover:bg-emerald-500 group-hover:text-white`}>
            <i data-lucide="arrow-right" class="w-7 h-7"></i>
        </a>
    </div>
</div>
