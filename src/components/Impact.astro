---
const goals = [
	{
		id: '01',
		title: '承諾一：推廣全民永續教育，深化知識基礎',
		description: '杉蔓深信，永續轉型的成功基於知識的普及。我們致力於開發多元且生動的教育工具，透過專利 ESG 策略桌遊與專業培訓，讓永續理念不再是晦澀的口號，而是具備行動力的知識儲備。',
		target: '量化目標：期許在 2030 年前，「培育 500 名」具備 ESG 知識的永續人才。',
		icon: 'users',
		color: 'emerald'
	},
	{
		id: '02',
		title: '承諾二：深化在地連結，共建永續供應鏈',
		description: '杉蔓從台灣在地農村出發，深入了解農村社區的永續需求，並提供實質幫助。我們扮演「專業媒合平台」，協助農友與重視 ESG 的企業建立穩定的合作關係，讓永續農產品能順利進入市場，同時協助企業落實社會責任。',
		target: '量化目標：期許在 2030 年前，「協助 20 個農村社區」落實永續耕作。',
		icon: 'map-pin',
		color: 'blue'
	},
	{
		id: '03',
		title: '承諾三：循環經濟，實踐綠色會展',
		description: '我們推廣專利循環經濟材料，將回收寶特瓶轉化為可重複黏貼的無毒布料，取代傳統高污染的一次性 PVC 耗材。讓每一次的商業展覽與空間佈置，都能成為對環境友善的具體行動，實踐展場零廢棄。',
		target: '量化目標：期許在 2030 年前，透過綠色印刷服務協助 50 場低碳策展，降低二氧化碳排放量。',
		icon: 'heart',
		color: 'yellow'
	}
];

const sdgs = [
	{ id: 4, name: '優質教育', color: 'bg-emerald-500' },
	{ id: 11, name: '永續城鄉', color: 'bg-yellow-500' },
	{ id: 17, name: '夥伴關係', color: 'bg-blue-500' }
];
---

<section class="py-40 px-6 relative overflow-hidden" id="impact">
    <!-- Background Decor -->
    <div class="absolute inset-x-0 top-0 h-px bg-gradient-to-r from-transparent via-emerald-500/20 to-transparent"></div>
    <div class="absolute top-1/2 left-0 w-[400px] h-[400px] bg-emerald-500/5 blur-[120px] rounded-full"></div>

    <div class="max-w-7xl mx-auto relative z-10">
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-24 items-start">
            <div class="lg:sticky lg:top-40">
                <h2 class="text-[10px] font-black uppercase tracking-[0.5em] text-emerald-500 mb-8 stagger-reveal flex items-center gap-4">
                    <span class="w-12 h-[1px] bg-emerald-500/30"></span>
                    Impact & Commitment / 我們的承諾
                </h2>
                <h3 class="text-6xl md:text-8xl font-black uppercase tracking-tighter mb-12 stagger-reveal delay-200 text-white leading-[0.8]">
                    AI 賦能 <br/> <span class="text-emerald-300/60">永續確信</span>
                </h3>
                <p class="text-xl md:text-2xl text-zinc-300 mb-16 stagger-reveal delay-400 leading-relaxed max-w-lg font-medium">
                    杉蔓的核心使命是：「結合 <strong class="text-emerald-400">AI 數據治理</strong> 與 <strong class="text-emerald-400">數位雙軸轉型策略</strong>，將 ESG 實踐從合規壓力轉化為企業競爭力，接軌全球綠色供應鏈。」
                </p>

                <div class="flex gap-6 stagger-reveal delay-500">
                    {sdgs.map(sdg => (
                        <div class={`w-32 h-28 ${sdg.color} p-5 flex flex-col justify-between group hover:-translate-y-2 transition-all duration-500 shadow-2xl rounded-sm relative overflow-hidden`}>
                            <div class="absolute inset-0 bg-black/10 transition-opacity opacity-0 group-hover:opacity-100"></div>
                            <span class="text-white font-black text-2xl italic uppercase relative z-10">SDG {sdg.id}</span>
                            <span class="text-white font-bold text-[10px] uppercase tracking-widest relative z-10">{sdg.name}</span>
                        </div>
                    ))}
                </div>
            </div>

            <div class="space-y-12">
                {goals.map((goal, index) => (
                    <div class="p-12 bg-zinc-900/80 border border-white/5 border-l-4 border-l-emerald-500 shadow-3xl stagger-reveal" style={`transition-delay: ${400 + index * 150}ms`}>
                        <header class="flex gap-10 items-start mb-10">
                            <span class="text-5xl font-black text-zinc-800 italic shrink-0">{goal.id}</span>
                            <h4 class="text-3xl font-black uppercase tracking-tighter text-white leading-tight">{goal.title}</h4>
                        </header>
                        <p class="text-zinc-300 font-medium tracking-wide text-md leading-relaxed mb-10">
                            {goal.description}
                        </p>
                        <div class="bg-emerald-500/5 p-6 border border-emerald-500/20 relative group rounded-sm shadow-inner">
                             <p class="text-xs font-black uppercase tracking-[0.2em] text-emerald-500 relative z-10">
                                {goal.target}
                             </p>
                        </div>
                    </div>
                ))}
            </div>
        </div>
    </div>
</section>
