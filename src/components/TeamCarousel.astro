---
import team from '../data/team.json';
---

<section class="py-12 md:py-20 bg-zinc-950 overflow-hidden relative flex flex-col justify-center" id="team">
    <!-- Premium Background Layers -->
    <div class="absolute inset-0 pointer-events-none">
        <div class="absolute top-0 left-1/4 w-[500px] h-[500px] bg-emerald-500/5 blur-[120px] rounded-full animate-pulse-slow"></div>
        <div class="absolute inset-0 opacity-[0.02]" style="background-image: url('data:image/svg+xml,%3Csvg viewBox=%220 0 200 200%22 xmlns=%22http://www.w3.org/2000/svg%22%3E%3Cfilter id=%22noiseFilter%22%3E%3CfeTurbulence type=%22fractalNoise%22 baseFrequency=%220.65%22 numOctaves=%223%22 stitchTiles=%22stitch%22/%3E%3C/filter%3E%3Crect width=%22100%25%22 height=%22100%25%22 filter=%22url(%23noiseFilter)%22/%3E%3C/svg%3E');"></div>
    </div>

    <!-- Background Watermark -->
    <div class="absolute top-1/2 left-0 w-full text-[15vw] font-black text-white/[0.01] tracking-tighter leading-none select-none pointer-events-none -translate-y-1/2 whitespace-nowrap uppercase">
        Consultants
    </div>

    <div class="max-w-7xl mx-auto w-full px-6 mb-10 flex justify-between items-end relative z-10">
        <div>
            <h2 class="text-[10px] font-black uppercase tracking-[0.5em] text-emerald-500 mb-3 stagger-reveal">Elite Experts</h2>
            <h3 class="text-4xl md:text-6xl font-black uppercase tracking-tighter leading-none stagger-reveal delay-200">
                專業顧問 <span class="text-zinc-800">團隊</span>
            </h3>
        </div>
    </div>

    <!-- Static Grid: all 5 members visible without scrolling -->
    <div id="teamGrid" class="max-w-7xl mx-auto w-full px-6 pb-10 relative z-10 grid grid-cols-2 md:grid-cols-3 xl:grid-cols-5 gap-5">
        {team.map((member, index) => (
            <div 
                class="team-card group relative"
                style={`--stagger: ${index}`}
            >
                <!-- Image Wrapper -->
                <div class="relative w-full aspect-[4/5] overflow-hidden bg-zinc-900 shadow-2xl transition-all duration-500 group-hover:shadow-emerald-500/10">
                    <!-- Hover Aura Glow -->
                    <div class="absolute -inset-2 bg-emerald-500/0 group-hover:bg-emerald-500/5 blur-2xl transition-all duration-700"></div>
                    
                    <img 
                        src={member.image} 
                        alt={member.name} 
                        class="w-full h-full object-cover object-top grayscale group-hover:grayscale-0 group-hover:scale-105 transition-all duration-700 ease-out" 
                        loading="lazy"
                    />
                    
                    <!-- Gradient Shadow -->
                    <div class="absolute inset-0 bg-gradient-to-b from-black/40 via-transparent to-black/80"></div>

                    <!-- Name/Role Info -->
                    <div class="absolute bottom-0 left-0 right-0 p-4 z-20 transition-all duration-500 group-hover:translate-y-[-110px]">
                        <p class="text-[8px] font-black uppercase tracking-[0.3em] text-emerald-500 mb-1">{member.role}</p>
                        <h4 class="text-base font-black uppercase tracking-tighter text-white leading-tight">{member.name}</h4>
                    </div>

                    <!-- Hover Reveal: Specialties -->
                    <div class="absolute inset-x-0 bottom-0 p-4 bg-black/80 backdrop-blur-xl border-t border-white/10 translate-y-full group-hover:translate-y-0 transition-transform duration-500 ease-out z-30 h-[120px] flex flex-col justify-center">
                        <p class="text-[7px] font-black uppercase tracking-widest text-zinc-500 mb-2">核心專長 / Expertise</p>
                        <ul class="space-y-1">
                            {member.specialties.slice(0, 3).map(spec => (
                                <li class="flex items-center gap-2 text-[9px] font-bold text-zinc-300">
                                    <div class="w-1 h-1 rounded-full bg-emerald-500 flex-shrink-0"></div>
                                    <span class="truncate">{spec}</span>
                                </li>
                            ))}
                            {member.specialties.length > 3 && (
                                <li class="text-[8px] text-zinc-600 italic pl-3">+ 更多專業背景</li>
                            )}
                        </ul>
                    </div>
                </div>
            </div>
        ))}
    </div>
</section>

<script>
    // Staggered Entry Animation
    const observer = new IntersectionObserver((entries) => {
        entries.forEach(entry => {
            if (entry.isIntersecting) {
                const cards = entry.target.querySelectorAll('.team-card');
                cards.forEach((card, i) => {
                    const el = card as HTMLElement;
                    el.animate(
                        [
                            { transform: 'translateY(40px)', opacity: '0' },
                            { transform: 'translateY(0)', opacity: '1' }
                        ], 
                        {
                            duration: 800,
                            delay: i * 100,
                            easing: 'cubic-bezier(0.16, 1, 0.3, 1)',
                            fill: 'forwards'
                        }
                    );
                });
                observer.unobserve(entry.target);
            }
        });
    }, { threshold: 0.1 });

    const teamSection = document.getElementById('team');
    if (teamSection) {
        const cards = teamSection.querySelectorAll('.team-card');
        cards.forEach(card => {
            const el = card as HTMLElement;
            el.style.opacity = '0';
        });
        observer.observe(teamSection);
    }
</script>

<style>
    .no-scrollbar::-webkit-scrollbar { display: none; }
    .no-scrollbar { -ms-overflow-style: none; scrollbar-width: none; }

    @keyframes pulse-slow {
        0%, 100% { transform: scale(1) translate(0, 0); opacity: 0.05; }
        50% { transform: scale(1.1) translate(20px, -20px); opacity: 0.08; }
    }
    .animate-pulse-slow {
        animation: pulse-slow 12s ease-in-out infinite;
    }

    .team-card {
        will-change: transform, opacity;
    }
</style>
