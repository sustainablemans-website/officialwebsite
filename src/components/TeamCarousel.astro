---
const team = [
	{
		name: '曾偉庭 (Wei-Ting Tseng)',
		role: '創辦人 暨 地方創生實踐家',
		specialties: ['ISO 14064-1 / 14067 主導查證員', 'IPAS 淨零碳規劃管理師', '永續桌遊培訓師', '農業永續轉型輔導'],
		image: 'https://drive.google.com/thumbnail?id=16mOnqgwo2Y0Xa2qEdQZwy2Dp084qiWji&sz=w500'
	},
	{
		name: '李崇毅',
		role: '資深策略顧問',
		specialties: ['成大鳳凰新創導師', '台灣碳盤查工會名譽理事長', '奔馳科技執行長', 'ESG 永續協會主委'],
		image: 'https://drive.google.com/thumbnail?id=10611Bl_T3cPrtG2b5QSVREtaQJVQSn6u&sz=w500'
	},
	{
		name: '鄭安姵',
		role: '資深永續輔導顧問',
		specialties: ['iPAS 淨零碳規劃管理師', 'ISO 14064 / 14067 / 14068 主導查證員', 'ISO 50001 能源管理', 'TTQS 人才培訓'],
		image: 'https://drive.google.com/thumbnail?id=1EsDULLlQL2uHVyvT_TiYYl5AwttrxLRV&sz=w500'
	},
    {
		name: '周家豪',
		role: '資深永續碳權顧問',
		specialties: ['益珂環能總經理', 'COP29 UNFCCC 特邀講者', '行銷博士', '再生能源輔導'],
		image: 'https://drive.google.com/thumbnail?id=1D0g4Dwb0t4WoEPIme65ArsfDPWhP9OsI&sz=w500'
	}
];
---

<section class="py-32 bg-zinc-900 overflow-hidden" id="team">
    <div class="max-w-7xl mx-auto px-6 mb-20">
        <h2 class="text-xs font-bold uppercase tracking-widest text-emerald-500 mb-4 stagger-reveal">專業顧問團隊</h2>
        <h3 class="text-5xl md:text-7xl font-black uppercase tracking-tighter stagger-reveal delay-200">
            永續轉型 <br/> <span class="text-zinc-500">堅實後盾</span>
        </h3>
    </div>

    <div class="flex overflow-x-auto snap-x snap-mandatory gap-8 px-6 pb-20 no-scrollbar">
        {team.map((member) => (
            <div class="snap-center flex-shrink-0 w-80 md:w-[28rem] bg-black border border-zinc-800 p-8 group hover:border-emerald-500 transition-all duration-500">
                <div class="relative w-full aspect-[3/4] mb-8 overflow-hidden">
                    <img 
                        src={member.image} 
                        alt={member.name} 
                        class="w-full h-full object-cover grayscale group-hover:grayscale-0 group-hover:scale-105 transition-all duration-700" 
                        loading="lazy"
                        onerror="this.src='https://placehold.co/600x800/059669/ffffff/png?text='+member.name"
                    />
                    <div class="absolute inset-0 bg-gradient-to-t from-black via-transparent opacity-60"></div>
                </div>

                <h4 class="text-2xl font-black uppercase tracking-tighter mb-1 text-emerald-500 group-hover:text-white transition-colors">{member.name}</h4>
                <p class="text-xs font-bold uppercase tracking-widest text-zinc-500 mb-6">{member.role}</p>
                
                <ul class="space-y-3">
                    {member.specialties.map(spec => (
                        <li class="flex items-start gap-2 text-xs font-bold uppercase tracking-widest text-zinc-400 group-hover:text-zinc-200 transition-colors">
                            <i data-lucide="check" class="w-4 h-4 text-emerald-500 flex-shrink-0"></i>
                            {spec}
                        </li>
                    ))}
                </ul>
            </div>
        ))}
    </div>
</section>

<style>
    .no-scrollbar::-webkit-scrollbar {
        display: none;
    }
    .no-scrollbar {
        -ms-overflow-style: none;
        scrollbar-width: none;
    }
</style>
