---
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import servicesData from '../../data/services.json';
const services = servicesData.services;

export function getStaticPaths() {
    return services.map(s => ({
        params: { slug: s.slug },
        props: { service: s }
    }));
}

const { service } = Astro.props;

const accentText: Record<string, string> = {
    emerald: 'text-emerald-400',
    blue: 'text-blue-400',
    yellow: 'text-yellow-400',
    purple: 'text-purple-400',
};
const accentBorder: Record<string, string> = {
    emerald: 'border-emerald-500',
    blue: 'border-blue-500',
    yellow: 'border-yellow-400',
    purple: 'border-purple-500',
};
const accentBg: Record<string, string> = {
    emerald: 'bg-emerald-500',
    blue: 'bg-blue-500',
    yellow: 'bg-yellow-400',
    purple: 'bg-purple-500',
};

const color = service.accent || 'emerald';

// ─────────────────────────────────────────────
// 自動讀取服務照片資料夾內的所有圖片
// 放置路徑：public/images/services/{slug}/
// 支援 jpg、jpeg、png、webp 格式
// ─────────────────────────────────────────────
const allImages = import.meta.glob<{ default: ImageMetadata }>(
    '/public/images/services/**/*.{jpg,jpeg,png,webp}',
    { eager: true }
);

// 篩選出屬於此服務的圖片，並轉換為可用的 src 路徑
const galleryImages = Object.entries(allImages)
    .filter(([path]) => path.includes(`/services/${service.slug}/`))
    .map(([path]) => path.replace('/public', ''))
    .sort();

// 封面圖：優先使用 services.json 中指定的 image，否則用 gallery 第一張
const coverImage = service.image || galleryImages[0] || null;
// 輪播照片：排除已作為封面的圖片
const carouselImages = galleryImages.filter(img => img !== coverImage);
---

<Layout title={`${service.title} | 杉蔓有限公司`} description={service.description}>
    <Header />
    <main class="pt-32 pb-24 min-h-screen text-white">

        <!-- Breadcrumb -->
        <div class="max-w-7xl mx-auto px-6 mb-12">
            <a href="/services/" class="inline-flex items-center gap-2 text-[10px] font-black uppercase tracking-[0.3em] text-zinc-500 hover:text-emerald-400 transition-colors">
                <i data-lucide="arrow-left" class="w-4 h-4"></i> 返回服務列表
            </a>
        </div>

        <!-- Hero Section -->
        <section class="max-w-7xl mx-auto px-6 mb-24">
            <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 items-center">
                <div>
                    <div class={`inline-flex items-center gap-2 px-4 py-2 ${accentBg[color]} text-black text-[10px] font-black uppercase tracking-[0.2em] rounded-lg mb-8`}>
                        <i data-lucide={service.icon} class="w-4 h-4"></i>
                        Our Services
                    </div>
                    <h1 class="text-5xl md:text-7xl font-black uppercase tracking-tighter leading-none mb-8 text-white">
                        {service.title}
                    </h1>
                    <p class={`text-xl text-zinc-300 leading-relaxed font-medium mb-10 border-l-4 ${accentBorder[color]} pl-6`}>
                        {service.description}
                    </p>
                    <a href="/contact/" class={`inline-flex items-center gap-3 px-10 py-5 ${accentBg[color]} text-black font-black uppercase text-xs tracking-[0.2em] hover:bg-white transition-all duration-300 rounded-xl shadow-xl`}>
                        立即洽詢 <i data-lucide="arrow-right" class="w-4 h-4"></i>
                    </a>
                </div>

                <!-- Cover Image or Stats -->
                <div>
                    {coverImage ? (
                        <div class="relative aspect-[4/3] overflow-hidden rounded-2xl border border-white/10 shadow-2xl group">
                            <img 
                                src={coverImage} 
                                alt={service.title}
                                class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-700"
                                loading="eager"
                            />
                            <div class="absolute inset-0 bg-gradient-to-t from-black/50 to-transparent"></div>
                        </div>
                    ) : service.stats ? (
                        <div class="grid grid-cols-3 gap-6">
                            {service.stats.map((stat: { label: string; value: string }) => (
                                <div class="p-6 bg-zinc-900/80 border border-white/5 rounded-2xl text-center">
                                    <p class={`text-3xl md:text-4xl font-black ${accentText[color]} mb-2`}>{stat.value}</p>
                                    <p class="text-[9px] font-bold text-zinc-500 uppercase tracking-widest">{stat.label}</p>
                                </div>
                            ))}
                        </div>
                    ) : null}
                </div>
            </div>
        </section>

        <!-- Stats Bar (if cover image is shown above) -->
        {coverImage && service.stats && (
            <section class="max-w-7xl mx-auto px-6 mb-16">
                <div class={`grid grid-cols-3 gap-6 p-8 bg-zinc-900/60 border border-white/5 rounded-2xl border-t-4 ${accentBorder[color]}`}>
                    {service.stats.map((stat: { label: string; value: string }) => (
                        <div class="text-center">
                            <p class={`text-3xl md:text-4xl font-black ${accentText[color]} mb-1`}>{stat.value}</p>
                            <p class="text-[9px] font-bold text-zinc-500 uppercase tracking-widest">{stat.label}</p>
                        </div>
                    ))}
                </div>
            </section>
        )}

        <!-- Divider -->
        <div class="max-w-7xl mx-auto px-6 mb-24">
            <div class="h-px bg-gradient-to-r from-transparent via-white/10 to-transparent"></div>
        </div>

        <!-- Detail Content -->
        <section class="max-w-7xl mx-auto px-6 mb-24">
            <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 items-start">
                <!-- Long Description -->
                <div>
                    <h2 class={`text-[10px] font-black uppercase tracking-[0.4em] ${accentText[color]} mb-6 flex items-center gap-4`}>
                        <span class="w-8 h-[1px] bg-current opacity-40"></span>
                        服務說明 / Overview
                    </h2>
                    <p class="text-lg text-zinc-300 leading-relaxed font-medium">
                        {service.longDescription}
                    </p>
                </div>

                <!-- Features -->
                {service.features && (
                    <div>
                        <h2 class={`text-[10px] font-black uppercase tracking-[0.4em] ${accentText[color]} mb-8 flex items-center gap-4`}>
                            <span class="w-8 h-[1px] bg-current opacity-40"></span>
                            核心特色 / Features
                        </h2>
                        <ul class="space-y-4">
                            {service.features.map((f: string) => (
                                <li class="flex items-start gap-4 p-4 bg-zinc-900/60 border border-white/5 rounded-xl">
                                    <div class={`w-1.5 h-1.5 rounded-full ${accentBg[color]} mt-2 flex-shrink-0`}></div>
                                    <span class="text-zinc-200 font-medium leading-relaxed">{f}</span>
                                </li>
                            ))}
                        </ul>
                    </div>
                )}
            </div>
        </section>

        <!-- Photo Gallery (只有在有額外照片時才顯示) -->
        {carouselImages.length > 0 && (
            <section class="max-w-7xl mx-auto px-6 mb-24">
                <h2 class={`text-[10px] font-black uppercase tracking-[0.4em] ${accentText[color]} mb-10 flex items-center gap-4`}>
                    <span class="w-8 h-[1px] bg-current opacity-40"></span>
                    實際案例 / Gallery
                </h2>
                <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
                    {carouselImages.map((src, i) => (
                        <div class="group relative aspect-[4/3] overflow-hidden rounded-2xl border border-white/5 hover:border-emerald-500/30 transition-all duration-500 cursor-zoom-in"
                             data-gallery-index={i}
                             data-gallery-src={src}>
                            <img
                                src={src}
                                alt={`${service.title} 案例照片 ${i + 1}`}
                                class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-700"
                                loading="lazy"
                            />
                            <div class="absolute inset-0 bg-black/0 group-hover:bg-black/20 transition-colors duration-500 flex items-center justify-center">
                                <i data-lucide="zoom-in" class="w-8 h-8 text-white opacity-0 group-hover:opacity-100 transition-opacity duration-300"></i>
                            </div>
                        </div>
                    ))}
                </div>
            </section>
        )}

        <!-- Lightbox -->
        <div id="lightbox" class="fixed inset-0 z-50 bg-black/90 backdrop-blur-xl hidden items-center justify-center" aria-modal="true">
            <button id="lightbox-close" class="absolute top-6 right-6 w-12 h-12 flex items-center justify-center text-white hover:text-emerald-400 transition-colors">
                <i data-lucide="x" class="w-8 h-8"></i>
            </button>
            <button id="lightbox-prev" class="absolute left-6 top-1/2 -translate-y-1/2 w-12 h-12 flex items-center justify-center text-white hover:text-emerald-400 transition-colors">
                <i data-lucide="chevron-left" class="w-8 h-8"></i>
            </button>
            <button id="lightbox-next" class="absolute right-6 top-1/2 -translate-y-1/2 w-12 h-12 flex items-center justify-center text-white hover:text-emerald-400 transition-colors">
                <i data-lucide="chevron-right" class="w-8 h-8"></i>
            </button>
            <img id="lightbox-img" src="" alt="" class="max-w-[90vw] max-h-[85vh] object-contain rounded-xl shadow-2xl" />
            <p id="lightbox-counter" class="absolute bottom-6 left-1/2 -translate-x-1/2 text-[10px] font-black uppercase tracking-widest text-zinc-500"></p>
        </div>

        <!-- CTA Footer -->
        <section class="max-w-7xl mx-auto px-6">
            <div class="p-12 md:p-16 bg-zinc-900/60 border border-white/5 rounded-3xl flex flex-col md:flex-row justify-between items-center gap-8">
                <div>
                    <h3 class="text-3xl md:text-4xl font-black uppercase tracking-tighter text-white mb-3">準備好啟動您的永續計畫了嗎？</h3>
                    <p class="text-zinc-400 font-medium uppercase tracking-widest text-sm">我們的顧問團隊隨時為您服務。</p>
                </div>
                <a href="/contact/" class={`flex-shrink-0 px-12 py-6 ${accentBg[color]} text-black font-black uppercase text-xs tracking-[0.3em] hover:bg-white transition-all duration-300 rounded-xl shadow-xl`}>
                    立即聯繫我們
                </a>
            </div>
        </section>
    </main>
    <Footer />
</Layout>

<script>
    // ─── Lightbox Logic ───────────────────────────────────────
    const galleryItems = document.querySelectorAll('[data-gallery-index]');
    const lightbox     = document.getElementById('lightbox') as HTMLElement;
    const lbImg        = document.getElementById('lightbox-img') as HTMLImageElement;
    const lbCounter    = document.getElementById('lightbox-counter') as HTMLElement;
    const lbClose      = document.getElementById('lightbox-close') as HTMLElement;
    const lbPrev       = document.getElementById('lightbox-prev') as HTMLElement;
    const lbNext       = document.getElementById('lightbox-next') as HTMLElement;

    const srcs = Array.from(galleryItems).map(el => el.getAttribute('data-gallery-src') || '');
    let current = 0;

    function openLightbox(index: number) {
        current = index;
        lbImg.src = srcs[current];
        lbImg.alt = `照片 ${current + 1}`;
        lbCounter.textContent = `${current + 1} / ${srcs.length}`;
        lightbox.classList.remove('hidden');
        lightbox.classList.add('flex');
        document.body.style.overflow = 'hidden';
    }

    function closeLightbox() {
        lightbox.classList.add('hidden');
        lightbox.classList.remove('flex');
        document.body.style.overflow = '';
    }

    galleryItems.forEach(el => {
        el.addEventListener('click', () => {
            const idx = parseInt(el.getAttribute('data-gallery-index') || '0', 10);
            openLightbox(idx);
        });
    });

    lbClose?.addEventListener('click', closeLightbox);
    lightbox?.addEventListener('click', (e) => { if (e.target === lightbox) closeLightbox(); });

    lbPrev?.addEventListener('click', () => openLightbox((current - 1 + srcs.length) % srcs.length));
    lbNext?.addEventListener('click', () => openLightbox((current + 1) % srcs.length));

    document.addEventListener('keydown', (e) => {
        if (lightbox.classList.contains('hidden')) return;
        if (e.key === 'Escape') closeLightbox();
        if (e.key === 'ArrowLeft') openLightbox((current - 1 + srcs.length) % srcs.length);
        if (e.key === 'ArrowRight') openLightbox((current + 1) % srcs.length);
    });
</script>
